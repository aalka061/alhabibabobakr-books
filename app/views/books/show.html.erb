<% content_for :title, "#{@book.title} — المكتبة الجدولية" %>
<% content_for :meta_description, "#{@book.title} — الجدول الزمني لقراءة المنظومات والتراجم. المكتبة الجدولية، مكتبة الحبيب أبو بكر." %>
<%# app/views/books/show.html.erb %>
<div class="min-h-screen bg-stone-50 font-['Amiri',serif]" dir="rtl">
  <%# ─── Sticky sub-header (matches library tone) ─── %>
  <header class="bg-white/95 backdrop-blur border-b border-stone-200 sticky top-0 z-20 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <%= link_to books_path,
            class: "flex items-center gap-3 text-stone-500 hover:text-sky-600 transition-colors text-sm font-medium group min-w-0 self-start sm:self-auto" do %>
        <img src="/logo.png" alt="" width="256" height="256" class="h-9 w-9 sm:h-10 sm:w-10 rounded-full object-cover opacity-95 group-hover:opacity-100 shrink-0 ring-1 ring-stone-200 shadow-sm" aria-hidden="true" />
        <span class="flex items-center gap-2 min-w-0">
          <svg class="w-4 h-4 shrink-0 group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
          <span class="truncate">العودة للمكتبة</span>
        </span>
      <% end %>
      <%= link_to edit_book_path(@book),
            class: "inline-flex items-center justify-center gap-2 bg-sky-600 hover:bg-sky-700 text-white text-sm font-semibold px-4 sm:px-5 py-2.5 rounded-xl transition-colors shadow-sm w-full sm:w-auto shrink-0" do %>
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        تعديل البيانات
      <% end %>
    </div>
  </header>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 sm:py-10 lg:py-12">
    <div class="flex flex-col xl:flex-row xl:items-start gap-8 lg:gap-10 xl:gap-14">
      <%# ── Sidebar: cover + actions (sticky on large screens) ── %>
      <aside class="w-full xl:w-[min(100%,20rem)] shrink-0 xl:sticky xl:top-24 space-y-5 sm:space-y-6">
        <div class="bg-white rounded-2xl border border-stone-100 shadow-sm overflow-hidden">
          <div class="aspect-[3/4] sm:aspect-[4/5] max-h-[min(70vh,28rem)] xl:max-h-none xl:aspect-[3/4] flex items-center justify-center p-4 sm:p-6 bg-gradient-to-b from-stone-50 to-stone-100/80">
            <% if @book.image_url.present? %>
              <%= image_tag @book.image_url,
                    class: "max-h-full max-w-full w-auto object-contain rounded-lg shadow-md",
                    alt: @book.title %>
            <% else %>
              <div class="flex flex-col items-center gap-3 text-stone-300 py-8">
                <svg class="w-14 h-14 sm:w-16 sm:h-16 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
                <span class="text-sm">لا توجد صورة غلاف</span>
              </div>
            <% end %>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-stone-100 shadow-sm p-4 sm:p-5 space-y-3">
          <p class="text-xs font-semibold text-stone-400 tracking-wide text-center sm:text-right">التنزيل والترجمة</p>
          <% if @book.pdf_url.present? %>
            <%= link_to @book.pdf_url, target: "_blank", rel: "noopener noreferrer",
                  class: "flex items-center justify-center gap-2.5 w-full bg-emerald-600 hover:bg-emerald-700 text-white py-3.5 px-4 rounded-xl text-sm sm:text-base font-bold shadow-sm hover:shadow transition-all" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
              </svg>
              تحميل الكتاب (PDF)
            <% end %>
          <% end %>
          <% if @book.translated_pdf_url.present? %>
            <%= link_to @book.translated_pdf_url, target: "_blank", rel: "noopener noreferrer",
                  class: "flex items-center justify-center gap-2.5 w-full bg-sky-600 hover:bg-sky-700 text-white py-3 px-4 rounded-xl text-sm font-bold shadow-sm hover:shadow transition-all" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
              </svg>
              English PDF
            <% end %>
          <% end %>
          <% if @book.translated_editable_url.present? %>
            <%= link_to @book.translated_editable_url, target: "_blank", rel: "noopener noreferrer",
                  class: "flex items-center justify-center gap-2.5 w-full bg-violet-600 hover:bg-violet-700 text-white py-3 px-4 rounded-xl text-sm font-bold shadow-sm hover:shadow transition-all" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              تعديل الترجمة (Google Docs)
            <% end %>
          <% end %>
          <% if @book.pdf_url.blank? && @book.translated_pdf_url.blank? && @book.translated_editable_url.blank? %>
            <p class="text-center text-sm text-stone-400 py-2">لا روابط PDF متاحة حالياً.</p>
          <% end %>
        </div>
      </aside>

      <%# ── Main article (full width on xl; was wrongly nested inside sidebar) ── %>
      <article class="flex-1 min-w-0 max-w-3xl xl:max-w-none">
        <div class="flex flex-wrap items-center gap-2 mb-4">
          <span class="inline-flex items-center bg-stone-100 text-stone-600 text-xs sm:text-sm font-medium px-3 py-1 rounded-full border border-stone-200/80">
            <%= @book.category&.name || "عام" %>
          </span>
          <% if @book.reading_month.present? %>
            <span class="text-xs text-stone-400 inline-flex items-baseline gap-2 flex-wrap" dir="rtl">
              <% if @book.day_of_month.present? %>
                <span class="tabular-nums font-medium text-stone-500"><%= eastern_arabic_numerals(@book.day_of_month) %></span>
              <% end %>
              <span class="font-serif text-stone-500"><%= @book.reading_month %></span>
              <span class="text-stone-400">قراءة:</span>
            </span>
          <% end %>
        </div>

        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-stone-900 leading-[1.35] tracking-tight mb-8">
          <%= @book.title %>
        </h1>

        <section class="rounded-2xl border border-amber-200/80 bg-gradient-to-br from-amber-50 to-orange-50/40 p-5 sm:p-6 mb-8 sm:mb-10 shadow-sm" aria-labelledby="reading-info-heading">
          <h2 id="reading-info-heading" class="text-amber-900 font-bold text-base sm:text-lg mb-4 sm:mb-5 flex items-center gap-2">
            <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-amber-100 text-amber-700 shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </span>
            معلومات القراءة والوفاة
          </h2>
          <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4 text-sm sm:text-base">
            <div class="sm:col-span-2">
              <dt class="text-stone-500 font-semibold text-xs sm:text-sm mb-1">التصنيف</dt>
              <dd>
                <span class="inline-flex bg-white/80 text-stone-700 px-3 py-1 rounded-lg text-sm border border-stone-200/60">
                  <%= @book.category&.name || "عام" %>
                </span>
              </dd>
            </div>
            <div>
              <dt class="text-stone-500 font-semibold text-xs sm:text-sm mb-1">شهر القراءة</dt>
              <dd class="text-stone-800 font-medium"><%= @book.reading_month.presence || "—" %></dd>
            </div>
            <div>
              <dt class="text-stone-500 font-semibold text-xs sm:text-sm mb-1">يوم الشهر</dt>
              <dd>
                <% if @book.day_of_month.present? %>
                  <span class="inline-flex bg-amber-100 text-amber-800 font-bold px-2.5 py-1 rounded-lg text-sm tabular-nums"><%= eastern_arabic_numerals(@book.day_of_month) %></span>
                <% else %>
                  <span class="text-stone-400">—</span>
                <% end %>
              </dd>
            </div>
            <div class="sm:col-span-2">
              <dt class="text-stone-500 font-semibold text-xs sm:text-sm mb-1">تاريخ الوفاة (هجري)</dt>
              <dd class="text-stone-800 font-mono text-sm sm:text-base break-all"><%= @book.hijri_death_date.presence || "—" %></dd>
            </div>
          </dl>
        </section>

        <section class="mb-8 sm:mb-10" aria-labelledby="about-heading">
          <h2 id="about-heading" class="text-stone-800 font-bold text-lg sm:text-xl pb-3 mb-4 border-b border-stone-200 flex items-center gap-2">
            <span class="h-1 w-8 rounded-full bg-sky-500 shrink-0"></span>
            عن الكتاب والمنظومة
          </h2>
          <div class="text-stone-600 text-base sm:text-lg leading-[1.85] text-justify max-w-prose xl:max-w-[42rem] [&>p]:mb-4 last:[&>p]:mb-0">
            <% if @book.description.present? %>
              <%= simple_format(@book.description) %>
            <% else %>
              <p class="text-stone-400 italic">لا يوجد وصف متاح لهذا الكتاب.</p>
            <% end %>
          </div>
        </section>

        <% if @book.url.present? %>
          <footer class="pt-6 border-t border-stone-200">
            <p class="text-xs font-bold text-stone-500 tracking-wide mb-2">رابط المصدر</p>
            <%= link_to @book.url, @book.url, target: "_blank", rel: "noopener noreferrer",
                  class: "text-sky-600 hover:text-sky-800 text-sm sm:text-base break-all underline-offset-2 hover:underline transition-colors" %>
          </footer>
        <% end %>
      </article>
    </div>
  </div>
</div>
