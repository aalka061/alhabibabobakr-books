<div class="book-show-container" style="direction: rtl; max-width: 1000px; margin: 0 auto; padding: 20px; font-family: 'Amiri', serif; line-height: 1.8;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 2px solid #eee; padding-bottom: 15px;">
    <%= link_to '← العودة للمكتبة', books_path, style: "text-decoration: none; color: #7f8c8d; font-weight: bold;" %>
    <div class="actions">
      <%= link_to 'تعديل البيانات (Edit)', edit_book_path(@book), style: "background: #3498db; color: white; padding: 8px 20px; border-radius: 5px; text-decoration: none; font-size: 14px;" %>
    </div>
  </div>
  <div style="display: flex; flex-wrap: wrap; gap: 40px;">
    <div style="flex: 1; min-width: 300px; text-align: center;">
      <% if @book.image_url.present? %>
        <%= image_tag @book.image_url, style: "width: 100%; max-width: 350px; border-radius: 8px; box-shadow: 0 10px 25px rgba(0,0,0,0.1);" %>
      <% else %>
        <div style="width: 100%; height: 400px; background: #f4f4f4; display: flex; align-items: center; justify-content: center; color: #bdc3c7; border-radius: 8px;">
          لا توجد صورة
        </div>
      <% end %>
      <div style="margin-top: 25px;">
        <% if @book.pdf_url.present? %>
          <%= link_to 'تحميل الكتاب (PDF)', @book.pdf_url, target: "_blank", style: "display: block; background: #27ae60; color: white; padding: 15px; border-radius: 8px; text-decoration: none; font-size: 18px; font-weight: bold; box-shadow: 0 4px 10px rgba(39, 174, 96, 0.3);" %>
        <% end %>
        <p style="margin-top: 15px; font-size: 14px; color: #95a5a6;">
          تاريخ النشر الأصلي: <%= @book.published_at %>
        </p>
      </div>
    </div>
    <div style="flex: 2; min-width: 350px;">
      <h1 style="color: #2c3e50; font-size: 32px; margin-top: 0;"><%= @book.title %></h1>
      <div style="background: #fff9f0; padding: 20px; border-right: 4px solid #f39c12; margin-bottom: 30px; border-radius: 4px;">
        <h3 style="margin-top: 0; color: #d35400;">معلومات القراءة والوفاة</h3>
        <ul style="list-style: none; padding: 0; margin: 0;">
          <li style="margin-bottom: 10px;">
            <strong>التصنيف:</strong>
            <span style="background: #eee; padding: 2px 10px; border-radius: 12px; font-size: 14px;">
              <%= @book.category&.name || "عام" %>
            </span>
          </li>
          <li style="margin-bottom: 10px;">
            <strong>شهر القراءة:</strong> <%= @book.reading_month.present? ? @book.reading_month : "غير محدد" %>
          </li>
          <li style="margin-bottom: 10px;">
            <strong>يوم الشهر:</strong> <%= @book.day_of_month.present? ? @book.day_of_month : "غير محدد" %>
          </li>
          <li style="margin-bottom: 10px;">
            <strong>تاريخ الوفاة (هجري):</strong> <%= @book.hijri_death_date.present? ? @book.hijri_death_date : "غير متوفر" %>
          </li>
        </ul>
      </div>
      <div class="book-description" style="color: #34495e; font-size: 18px; text-align: justify;">
        <h3 style="border-bottom: 1px solid #eee; padding-bottom: 10px;">عن الكتاب والمنظومة</h3>
        <% if @book.description.present? %>
          <%# Using simple_format to preserve line breaks from the scraper %>
          <%= simple_format(@book.description) %>
        <% else %>
          <p style="color: #bdc3c7;">لا يوجد وصف متاح لهذا الكتاب.</p>
        <% end %>
      </div>
      <div style="margin-top: 40px; border-top: 1px solid #eee; padding-top: 20px;">
        <strong>رابط المصدر:</strong>
        <%= link_to @book.url, @book.url, target: "_blank", style: "word-break: break-all; font-size: 12px; color: #3498db;" %>
      </div>
    </div>
  </div>
</div>
<style>
  /* Optional: Styling for text generated by simple_format */
  .book-description p {
    margin-bottom: 15px;
  }
</style>