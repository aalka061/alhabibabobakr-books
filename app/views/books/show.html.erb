<%# app/views/books/show.html.erb %>
<div class="min-h-screen bg-stone-50" dir="rtl">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <%# ─── Top nav bar ─── %>
    <div class="flex items-center justify-between mb-8 pb-5 border-b border-stone-200">
      <%= link_to books_path,
            class: "flex items-center gap-3 text-stone-400 hover:text-sky-600 transition-colors text-sm font-medium group min-w-0" do %>
        <img src="/logo.png" alt="" width="256" height="256" class="h-8 w-8 rounded-full object-cover opacity-90 group-hover:opacity-100 shrink-0 ring-1 ring-stone-200" aria-hidden="true" />
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
          العودة للمكتبة
        </span>
      <% end %>
      <%= link_to edit_book_path(@book),
            class: "flex items-center gap-2 bg-sky-500 hover:bg-sky-600 text-white text-sm px-5 py-2 rounded-xl transition-colors shadow-sm" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        تعديل البيانات
      <% end %>
    </div>
    <%# ─── Main content ─── %>
    <div class="flex flex-col lg:flex-row gap-10">
      <%# ── Left column: cover + download ── %>
      <div class="lg:w-72 shrink-0 flex flex-col items-center gap-6">
        <%# Book cover %>
        <div class="w-full bg-white rounded-2xl border border-stone-100 shadow-sm overflow-hidden flex items-center justify-center p-6 min-h-80">
          <% if @book.image_url.present? %>
            <%= image_tag @book.image_url,
                  class: "w-full max-w-xs rounded-lg shadow-lg object-contain",
                  alt: @book.title %>
          <% else %>
            <div class="flex flex-col items-center gap-3 text-stone-300 py-10">
              <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
              <span class="text-sm font-serif">لا توجد صورة</span>
            </div>
          <% end %>
        </div>
        <%# PDF download buttons %>
        <div class="flex flex-col gap-3 w-full">
          <div class="flex flex-col gap-3 w-full">
            <%# Arabic PDF %>
            <% if @book.pdf_url.present? %>
              <%= link_to @book.pdf_url, target: "_blank",
          class: "w-full flex items-center justify-center gap-3 bg-emerald-500 hover:bg-emerald-600 text-white py-4 px-6 rounded-2xl text-lg font-bold font-serif shadow-md hover:shadow-lg transition-all duration-200" do %>
                <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                </svg>
                تحميل الكتاب (PDF)
              <% end %>
            <% end %>
            <%# English PDF %>
            <% if @book.translated_pdf_url.present? %>
              <%= link_to @book.translated_pdf_url, target: "_blank",
          class: "w-full flex items-center justify-center gap-3 bg-sky-500 hover:bg-sky-600 text-white py-3 px-6 rounded-2xl text-base font-bold shadow-md hover:shadow-lg transition-all duration-200" do %>
                <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
                </svg>
                English Translation (PDF)
              <% end %>
            <% end %>
            <%# Editable English version %>
            <% if @book.translated_editable_url.present? %>
              <%= link_to @book.translated_editable_url, target: "_blank",
          class: "w-full flex items-center justify-center gap-3 bg-violet-500 hover:bg-violet-600 text-white py-3 px-6 rounded-2xl text-base font-bold shadow-md hover:shadow-lg transition-all duration-200" do %>
                <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Edit English Translation (Google Docs)
              <% end %>
            <% end %>
          </div>
        </div>
        <%# ── Right column: details ── %>
        <div class="flex-1 min-w-0">
          <%# Title %>
          <h1 class="text-3xl font-bold text-stone-800 font-serif leading-snug mb-6">
            <%= @book.title %>
          </h1>
          <%# Reading / death info card %>
          <div class="bg-amber-50 border-r-4 border-amber-400 rounded-xl p-6 mb-8">
            <h3 class="text-amber-700 font-bold font-serif text-lg mt-0 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              معلومات القراءة والوفاة
            </h3>
            <dl class="space-y-3 text-sm">
              <div class="flex items-center gap-3 flex-wrap">
                <dt class="font-bold text-stone-600 w-40 shrink-0">التصنيف:</dt>
                <dd>
                  <span class="bg-stone-100 text-stone-600 px-3 py-0.5 rounded-full text-xs">
                    <%= @book.category&.name || "عام" %>
                  </span>
                </dd>
              </div>
              <div class="flex items-center gap-3 flex-wrap">
                <dt class="font-bold text-stone-600 w-40 shrink-0">شهر القراءة:</dt>
                <dd class="text-stone-700">
                  <%= @book.reading_month.present? ? @book.reading_month : "غير محدد" %>
                </dd>
              </div>
              <div class="flex items-center gap-3 flex-wrap">
                <dt class="font-bold text-stone-600 w-40 shrink-0">يوم الشهر:</dt>
                <dd>
                  <% if @book.day_of_month.present? %>
                    <span class="bg-amber-100 text-amber-700 font-bold px-3 py-0.5 rounded-full text-xs">
                      <%= @book.day_of_month %>
                    </span>
                  <% else %>
                    <span class="text-stone-400">غير محدد</span>
                  <% end %>
                </dd>
              </div>
              <div class="flex items-center gap-3 flex-wrap">
                <dt class="font-bold text-stone-600 w-40 shrink-0">تاريخ الوفاة (هجري):</dt>
                <dd class="text-stone-700 font-mono text-xs">
                  <%= @book.hijri_death_date.present? ? @book.hijri_death_date : "غير متوفر" %>
                </dd>
              </div>
            </dl>
          </div>
          <%# Description %>
          <div class="mb-8">
            <h3 class="text-stone-700 font-bold font-serif text-xl pb-3 mb-4 border-b border-stone-200">
              عن الكتاب والمنظومة
            </h3>
            <div class="text-stone-600 text-lg leading-loose font-serif text-justify [&>p]:mb-4">
              <% if @book.description.present? %>
                <%= simple_format(@book.description) %>
              <% else %>
                <p class="text-stone-300 italic">لا يوجد وصف متاح لهذا الكتاب.</p>
              <% end %>
            </div>
          </div>
          <%# Source URL %>
          <% if @book.url.present? %>
            <div class="pt-5 border-t border-stone-100 flex items-start gap-2 flex-wrap">
              <span class="font-bold text-stone-500 text-sm shrink-0">رابط المصدر:</span>
              <%= link_to @book.url, @book.url, target: "_blank",
                  class: "text-sky-500 hover:text-sky-700 text-xs break-all transition-colors" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>