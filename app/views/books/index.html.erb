<div class="library-container" style="direction: rtl; max-width: 1200px; margin: 0 auto; padding: 30px; font-family: 'Amiri', serif;">
  <header style="text-align: center; margin-bottom: 60px; border-bottom: 2px solid #f0f0f0; padding-bottom: 30px;">
    <h1 style="color: #2c3e50; font-size: 42px; margin-bottom: 10px;">المكتبة الجدولية</h1>
    <p style="color: #7f8c8d; font-size: 18px;">الجدول الزمني للقراءة المنظومية حسب أشهر الوفاة</p>
  </header>
  <% @hijri_order.each do |month| %>
    <% books = @books_by_month[month] %>
    <section class="month-section" style="margin-bottom: 60px;">
      <div style="display: flex; align-items: center; margin-bottom: 25px;">
        <h2 style="margin: 0; color: #2980b9; font-size: 28px; background: #ebf5fb; padding: 5px 25px; border-radius: 50px; border: 1px solid #d6eaf8;">
          <%= month %>
        </h2>
        <div style="flex-grow: 1; height: 1px; background: #d6eaf8; margin-right: 20px;"></div>
        <span style="color: #bdc3c7; font-size: 14px; margin-right: 15px;">
          إجمالي الكتب: <%= books&.count || 0 %>
        </span>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 30px;">
        <% if books.present? %>
          <%# Sort books by day of month (integer conversion for accuracy) %>
          <% books.sort_by { |b| b.day_of_month.to_i }.each do |book| %>
            <div class="book-card" style="background: white; border: 1px solid #eee; border-radius: 12px; overflow: hidden; display: flex; flex-direction: column; transition: transform 0.3s, box-shadow 0.3s;" 
                 onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.08)'" 
                 onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
              <div style="background: #f9f9f9; height: 280px; position: relative; display: flex; align-items: center; justify-content: center; padding: 15px;">
                <% if book.image_url.present? %>
                  <img src="<%= book.image_url %>" style="max-width: 100%; max-height: 100%; object-fit: contain; filter: drop-shadow(0 5px 10px rgba(0,0,0,0.1));">
                <% else %>
                  <div style="color: #bdc3c7; font-size: 14px;">لا يوجد غلاف</div>
                <% end %>
                <div style="position: absolute; top: 15px; left: 15px; background: #f39c12; color: white; padding: 2px 12px; border-radius: 20px; font-size: 14px; font-weight: bold;">
                  يوم <%= book.day_of_month.present? ? book.day_of_month : "?" %>
                </div>
              </div>
              <div style="padding: 20px; flex-grow: 1; display: flex; flex-direction: column;">
                <h4 style="margin: 0 0 10px 0; font-size: 18px; line-height: 1.4; height: 50px; overflow: hidden;">
                  <%= link_to book.title, book_path(book), style: "text-decoration: none; color: #2c3e50; transition: color 0.2s;", onmouseover: "this.style.color='#2980b9'", onmouseout: "this.style.color='#2c3e50'" %>
                </h4>
                <div style="font-size: 13px; color: #95a5a6; margin-bottom: 15px;">
                  <span style="background: #f4f4f4; padding: 2px 8px; border-radius: 4px;">
                    <%= book.category&.name || "عام" %>
                  </span>
                </div>
                <div style="margin-top: auto; display: flex; gap: 10px;">
                  <%= link_to "التفاصيل", book_path(book), style: "flex: 1; text-align: center; border: 1px solid #3498db; color: #3498db; padding: 8px; border-radius: 6px; text-decoration: none; font-size: 14px;" %>
                  <% if book.pdf_url.present? %>
                    <%= link_to "PDF", book.pdf_url, target: "_blank", style: "background: #27ae60; color: white; padding: 8px 15px; border-radius: 6px; text-decoration: none; font-size: 14px;" %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div style="grid-column: 1 / -1; padding: 40px; text-align: center; border: 2px dashed #f0f0f0; border-radius: 12px; color: #bdc3c7;">
            لا توجد كتب مخصصة لشهر <%= month %> حالياً.
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
  <% if @unsorted_books.any? %>
    <section style="margin-top: 80px; background: #fdfdfd; padding: 40px; border-radius: 15px; border: 1px solid #eee;">
      <h2 style="color: #7f8c8d; margin-top: 0; border-bottom: 1px solid #eee; padding-bottom: 15px;">كتب إضافية (غير مؤرخة)</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 15px;">
        <% @unsorted_books.each do |book| %>
          <div style="padding: 10px; border-right: 3px solid #ddd;">
            <%= link_to book.title, book_path(book), style: "text-decoration: none; color: #34495e;" %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
<style>
  /* Ensuring fonts look clean */
  body {
    background-color: #fbfbfb;
  }

  /* Smooth scroll for better user experience */
  html {
    scroll-behavior: smooth;
  }
</style>