<div class="book-edit-container" style="direction: rtl; max-width: 900px; margin: 0 auto; padding: 20px; font-family: 'Amiri', serif;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 2px solid #eee; padding-bottom: 15px;">
    <h1 style="color: #2c3e50; margin: 0; font-size: 24px;">تعديل بيانات الكتاب: <%= @book.title %></h1>
    <%= link_to 'إلغاء (Cancel)', book_path(@book), style: "text-decoration: none; color: #e74c3c; font-weight: bold;" %>
  </div>
  <%= form_with(model: @book, local: true, class: "modern-form") do |f| %>
    <% if @book.errors.any? %>
      <div style="background: #fee; border: 1px solid #f99; padding: 15px; border-radius: 8px; margin-bottom: 25px; color: #c0392b;">
        <h4 style="margin-top: 0;">يرجى تصحيح الأخطاء التالية:</h4>
        <ul style="margin-bottom: 0;">
          <% @book.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <div style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #eee;">
      <div class="form-group" style="margin-bottom: 20px;">
        <%= f.label :title, "عنوان الكتاب", style: "display: block; font-weight: bold; color: #34495e; margin-bottom: 8px;" %>
        <%= f.text_field :title, class: "form-input" %>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div class="form-group">
          <%= f.label :category_id, "التصنيف", style: "display: block; font-weight: bold; color: #34495e; margin-bottom: 8px;" %>
          <%= f.collection_select :category_id, Category.all, :id, :name, { prompt: "اختر التصنيف" }, { class: "form-input" } %>
        </div>
        <div class="form-group">
          <%= f.label :pdf_url, "رابط الـ PDF", style: "display: block; font-weight: bold; color: #34495e; margin-bottom: 8px;" %>
          <%= f.text_field :pdf_url, class: "form-input", dir: "ltr" %>
        </div>
      </div>
      <div style="background: #fffcf5; padding: 20px; border-radius: 8px; border: 1px dashed #f39c12; margin-bottom: 25px;">
        <h4 style="margin-top: 0; color: #d35400; border-bottom: 1px solid #ffeaa7; padding-bottom: 10px;">بيانات الوفاة والقراءة</h4>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-top: 15px;">
          <div class="form-group">
            <%= f.label :reading_month, "شهر القراءة", style: "display: block; font-size: 14px; margin-bottom: 5px;" %>
            <%= f.select :reading_month, 
                ["محرم", "صفر", "ربيع الأول", "ربيع الثاني", "جمادى الأولى", "جمادى الآخرة", "رجب", "شعبان", "رمضان", "شوال", "ذو القعدة", "ذو الحجة"], 
                { include_blank: "اختر الشهر" }, 
                { class: "form-input" } %>
          </div>
          <div class="form-group">
            <%= f.label :day_of_month, "يوم الشهر", style: "display: block; font-size: 14px; margin-bottom: 5px;" %>
            <%= f.text_field :day_of_month, placeholder: "مثال: 19", class: "form-input" %>
          </div>
          <div class="form-group">
            <%= f.label :hijri_death_date, "تاريخ الوفاة الكامل", style: "display: block; font-size: 14px; margin-bottom: 5px;" %>
            <%= f.text_field :hijri_death_date, placeholder: "مثال: 1431هـ", class: "form-input" %>
          </div>
        </div>
      </div>
      <div class="form-group" style="margin-bottom: 20px;">
        <%= f.label :image_url, "رابط صورة الغلاف", style: "display: block; font-weight: bold; color: #34495e; margin-bottom: 8px;" %>
        <%= f.text_field :image_url, class: "form-input", dir: "ltr" %>
      </div>
      <div class="form-group" style="margin-bottom: 25px;">
        <%= f.label :description, "وصف الكتاب / نص المنظومة", style: "display: block; font-weight: bold; color: #34495e; margin-bottom: 8px;" %>
        <%= f.text_area :description, rows: 12, class: "form-input", style: "resize: vertical; font-family: inherit; font-size: 16px;" %>
      </div>
      <div style="text-align: left; padding-top: 20px; border-top: 1px solid #eee;">
        <%= f.submit "حفظ التغييرات (Save Changes)", style: "background: #27ae60; color: white; padding: 12px 40px; border: none; border-radius: 6px; font-size: 18px; font-weight: bold; cursor: pointer; box-shadow: 0 4px 10px rgba(39, 174, 96, 0.2);" %>
      </div>
    </div>
  <% end %>
</div>
<style>
  .form-input {
    width: 100%;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 16px;
    box-sizing: border-box; /* Ensures padding doesn't affect width */
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .form-input:focus {
    outline: none;
    border-color: #3498db;
    box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.1);
  }

  /* Responsive Grid for mobile */
  @media (max-width: 600px) {
    div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
    div[style*="grid-template-columns: 1fr 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>